class Libro:
    def __init__(self, titulo, autor, numero_paginas):
        self.titulo = titulo
        self.autor = autor
        self.numero_paginas = numero_paginas
    
    def mostrar_informacion(self):
        print("=" * 40)
        print("INFORMACIÓN DEL LIBRO")
        print("=" * 40)
        print(f"Título: {self.titulo}")
        print(f"Autor: {self.autor}")
        print(f"Número de páginas: {self.numero_paginas}")
        print("=" * 40)
    
    def actualizar_paginas(self, nuevo_numero_paginas):
        if nuevo_numero_paginas > 0:
            self.numero_paginas = nuevo_numero_paginas
            print(f"El número de páginas ha sido actualizado a: {self.numero_paginas}")
        else:
            print("Error: El número de páginas debe ser mayor a 0.")


# Ejemplo de uso
if __name__ == "__main__":
    # Registro de un libro
    libro1 = Libro("Cien Años de Soledad", "Gabriel García Márquez", 417)
    
    # MostrarSe muestra la información del libro
    libro1.mostrar_informacion()
    
    # Se actualiza el número de páginas
    libro1.actualizar_paginas(422)
    
